# 复制为 .env 后填写。.env 已被 .gitignore 忽略，不会提交。
# 注意：注释一律单独成行，不要写在「值」后面——docker run --env-file 和老版 compose
#       不会剥掉行内注释，会把注释连进值里（导致 Key/URL 失效）。

# ---- 总结 LLM（OpenAI 兼容端点；URL + Key 必填，默认 DeepSeek）----
# 兼容端点地址，可换成任意 OpenAI 兼容服务
LLM_BASE_URL=https://api.deepseek.com/v1
# 对应服务的 API Key
LLM_API_KEY=sk-your-key-here
# 模型名（按你的服务实际可用模型填）
LLM_MODEL=deepseek-v4-pro

# ---- 本地 ASR（FunASR）：始终本地离线，音频不出本机 ----
# auto=有 GPU 自动用 GPU，否则 CPU；也可写死 cpu / cuda / cuda:0
FUNASR_DEVICE=auto
# 预设说话人数：留空=自动估计(长音频可能塌缩成1人)，填数字更稳
FUNASR_SPK_NUM=3
