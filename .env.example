# 复制为 .env 后填写。.env 已被 .gitignore 忽略，不会提交。

# ---- 总结 LLM（OpenAI 兼容端点；URL + Key 必填，默认 DeepSeek）----
LLM_BASE_URL=https://api.deepseek.com/v1   # 兼容端点地址，可换成任意 OpenAI 兼容服务
LLM_API_KEY=sk-your-key-here               # 对应服务的 API Key
LLM_MODEL=deepseek-v4-pro                  # 模型名（按你的服务实际可用模型填）

# ---- 本地 ASR（FunASR）：始终本地离线，音频不出本机 ----
FUNASR_DEVICE=auto                         # auto=有 GPU 自动用 GPU，否则 CPU；也可写死 cpu / cuda / cuda:0
FUNASR_SPK_NUM=3                           # 预设说话人数：留空=自动估计(长音频可能塌缩成1人)，填数字更稳
